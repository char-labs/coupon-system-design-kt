# Copy this file to ~/.env for local Docker compose usage.
# Do not commit your real home .env.

MYSQL_DATABASE=coupon-db
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_USER=coupon-admin
MYSQL_PASSWORD=change-me-db-password

DATASOURCE_DB_CORE_USERNAME=coupon-admin
DATASOURCE_DB_CORE_PASSWORD=change-me-db-password

# Optional overrides:
# ADMIN_PASSWORD=change-me-admin-password
# JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-bytes-long
