# Shared local environment variables for coupon-system-design.
# Copy this file to `.env` at the repository root for local-only secrets.

# Load-test Slack notifications
LOAD_TEST_SLACK_WEBHOOK=
LOAD_TEST_SLACK_NOTIFY_ON=always
# LOAD_TEST_PROFILE=local

# coupon-worker outbox DEAD Slack alert
WORKER_OUTBOX_DEAD_SLACK_ENABLED=true
WORKER_OUTBOX_DEAD_SLACK_WEBHOOK_URL=
# WORKER_OUTBOX_DEAD_SLACK_TIMEOUT=3s

# Manual live smoke test switch. Keep false by default.
# WORKER_OUTBOX_DEAD_SLACK_LIVE_TEST_ENABLED=false
