# Shared environment variables for coupon-system-design.
# Copy this file to `.env` at the repository root and replace the secrets.
#
# `docker/docker-compose.prod.yml` is designed to read the repository-root `.env`
# automatically when you run `docker compose -f docker/docker-compose.prod.yml ...`
# from the repository root.

# Production single-host compose
COUPON_API_DOMAIN=coupon-api.yogieat.com
APP_HOST_PORT=18080
WORKER_HOST_PORT=18081
MYSQL_HOST_BIND=127.0.0.1
MYSQL_HOST_PORT=3306
KAFKA_UI_HOST_PORT=18085
GRAFANA_HOST_PORT=3000
LOKI_HOST_PORT=3100
ALLOY_HOST_PORT=12345
INFLUXDB_HOST_PORT=8086

MYSQL_DATABASE=coupon-db
MYSQL_USER=coupon-admin
MYSQL_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password

JWT_SECRET_KEY=change-me-jwt-secret
ACCESS_TOKEN_EXPIRATION_SECONDS=2880
REFRESH_TOKEN_EXPIRATION_SECONDS=43200

APP_JAVA_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UseStringDeduplication -XX:+ExitOnOutOfMemoryError -Dspring.backgroundpreinitializer.ignore=true
WORKER_JAVA_OPTS=-Xms192m -Xmx384m -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UseStringDeduplication -XX:+ExitOnOutOfMemoryError -Dspring.backgroundpreinitializer.ignore=true
KAFKA_HEAP_OPTS=-Xms512m -Xmx768m

APP_DB_POOL_MAX=12
APP_DB_POOL_MIN_IDLE=4
APP_TOMCAT_THREADS_MAX=80
APP_TOMCAT_THREADS_MIN_SPARE=10
APP_TOMCAT_MAX_CONNECTIONS=4096
APP_ASYNC_CORE_SIZE=4
APP_ASYNC_MAX_SIZE=4
APP_ASYNC_QUEUE_CAPACITY=1000

WORKER_DB_POOL_MAX=8
WORKER_DB_POOL_MIN_IDLE=2
WORKER_KAFKA_CONCURRENCY=1
WORKER_KAFKA_PERMITS_PER_SECOND=60

COUPON_ISSUE_TOPIC_PARTITIONS=3
COUPON_ISSUE_TOPIC_REPLICAS=1
API_KAFKA_COUPON_ISSUE_ACK_TIMEOUT=10s

SENTRY_DSN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
INFLUXDB_DB=myk6db

# Load-test Slack notifications
LOAD_TEST_SLACK_WEBHOOK=
LOAD_TEST_SLACK_NOTIFY_ON=always
# LOAD_TEST_PROFILE=local

# coupon-worker outbox DEAD Slack alert
WORKER_OUTBOX_DEAD_SLACK_ENABLED=true
WORKER_OUTBOX_DEAD_SLACK_WEBHOOK_URL=
# WORKER_OUTBOX_DEAD_SLACK_TIMEOUT=3s

# Manual live smoke test switch. Keep false by default.
# WORKER_OUTBOX_DEAD_SLACK_LIVE_TEST_ENABLED=false
